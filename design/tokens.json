    "glass": {
      "bg":        { "value": "#04070D", "use": "glass base — iOS + share cards only" },
      "panel":     { "value": "rgba(125,160,255,0.06)", "use": "frosted panel fill" },
      "border":    { "value": "rgba(140,175,255,0.16)", "use": "frosted panel border" },
      "ink":       { "value": "#E9EEF8", "use": "primary text on glass" },
      "inkDim":    { "value": "#8B96AF", "use": "secondary text on glass" },
      "accent":    { "value": "#6ED2FF", "use": "glass accent" },
      "accentInk": { "value": "#04121C", "use": "text on accent fills" },
      "up":        { "value": "#46DB9B", "use": "up moves (glass surfaces)" },
      "down":      { "value": "#FF5A57", "use": "down moves (glass surfaces) — matches --st-red risk system, no pink drift" },
      "warn":      { "value": "#F5B84A", "use": "elevated states (glass surfaces)" },
      "glow":      { "value": "0 0 60px rgba(110,210,255,0.10)", "use": "hero glow — max 3 glass layers per screen" }
    },
    "shareHeat": {
      "green": { "value": "#2BD576", "use": "share cards: heat <70" },
