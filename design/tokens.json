  "color": {
    "web": {
      "bg0":          { "value": "#0B0F0D", "use": "page background — toned graphite-green, never #000" },
      "bg1":          { "value": "#101613", "use": "panel / card background" },
      "bg2":          { "value": "#15201A", "use": "raised / hover background" },
      "border":       { "value": "#1E2822", "use": "hairline borders, dividers, heat-bar track" },
      "borderStrong": { "value": "#2C3A32", "use": "hover borders, secondary button outline" },
      "ink":          { "value": "#DDE6E0", "use": "primary text" },
      "inkDim":       { "value": "#7E8C84", "use": "secondary text, labels — AA on bg0 at >=12px" },
      "inkFaint":     { "value": "#5A665F", "use": "disabled, tertiary metadata" },
      "green":        { "value": "#3BE08F", "use": "brand accent, up moves, links, primary buttons, focus" },
      "greenInk":     { "value": "#06120C", "use": "text on green fills" },
      "red":          { "value": "#FF5A57", "use": "down moves, destructive, heat >=85. Risk only, never decoration" },
      "amber":        { "value": "#F2B33D", "use": "warnings, elevated states, heat 70-84" },
      "linkHover":    { "value": "#7FEDB6", "use": "link hover" },
