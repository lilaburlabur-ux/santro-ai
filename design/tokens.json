      "red":   { "value": "#FF4438", "use": "share cards: heat >=85" }
    },
    "heatBands": {
      "cool":     { "range": "< 70",  "token": "green" },
      "elevated": { "range": "70-84", "token": "amber" },
      "crowded":  { "range": ">= 85", "token": "red" }
    }
  },
